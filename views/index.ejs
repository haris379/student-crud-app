<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 flex justify-center items-center text-white">

  <div class="bg-zinc-800 p-8 rounded-2xl w-full max-w-md shadow-lg">

    <h1 class="text-2xl font-bold mb-6 text-center">🎓 Add Student</h1>

    <% if (success) { %>
      <p class="text-green-500 text-center mb-3"><%= success %></p>
    <% } %>

    <% if (error) { %>
      <p class="text-red-500 text-center mb-3"><%= error %></p>
    <% } %>

    <form action="/create" method="post" class="flex flex-col gap-4">

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        placeholder="Name"
        name="name"
      />

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        placeholder="Email"
        name="email"
      />

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        placeholder="Course"
        name="course"
      />

      <button class="bg-blue-500 py-2 rounded-lg hover:bg-blue-600 transition">
        Add Student
      </button>

      <a href="/read" class="text-center text-zinc-400 hover:text-white">
        View All Students →
      </a>

    </form>

  </div>

</div>
</body>
</html>