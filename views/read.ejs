<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
   <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-bold">All Students</h1>
    <a class="bg-blue-500 px-4 py-2 rounded-lg hover:bg-blue-600 transition" href="/">
      + Add Student
    </a>
  </div>

  <% if (students.length <= 0) { %>
    <div class="text-center mt-20">
      <h3 class="text-zinc-500 text-xl">No students yet 😔</h3>
    </div>
  <% } else { %>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <% students.forEach((student)=>{ %>
        
        <div class="bg-zinc-800 p-6 rounded-2xl shadow-lg hover:scale-105 transition duration-300">
          
          <h3 class="text-xl font-semibold mb-2">
            👤 <%= student.name %>
          </h3>

          <p class="text-sm text-zinc-300">
            📧 <%= student.email %>
          </p>

          <p class="text-sm text-zinc-400 mt-1">
            🎓 <%= student.course %>
          </p>

          <div class="flex justify-between mt-6">
            <a 
              class="bg-yellow-500 px-3 py-1 rounded hover:bg-yellow-600 transition text-sm"
              href="/edit/<%= student._id %>"
            >
              Edit
            </a>

            <a 
              class="bg-red-500 px-3 py-1 rounded hover:bg-red-600 transition text-sm"
              href="/delete/<%= student._id %>"
            >
              Delete
            </a>
          </div>

        </div>

      <% }) %>

    </div>

  <% } %>
</div>
  </body>
</html>
