<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 flex justify-center items-center text-white">

  <div class="bg-zinc-800 p-8 rounded-2xl w-full max-w-md shadow-lg">

    <h1 class="text-2xl font-bold mb-6 text-center">✏️ Edit Student</h1>

    <form action="/update/<%= student._id %>" method="post" class="flex flex-col gap-4">

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        name="name"
        value="<%= student.name %>"
      />

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        name="email"
        value="<%= student.email %>"
      />

      <input
        class="px-4 py-2 bg-zinc-900 border border-zinc-700 rounded-lg outline-none focus:border-blue-500"
        type="text"
        name="course"
        value="<%= student.course %>"
      />

      <button class="bg-yellow-500 py-2 rounded-lg hover:bg-yellow-600 transition">
        Update Info
      </button>

      <a href="/read" class="text-center text-zinc-400 hover:text-white">
        ← Back
      </a>

    </form>

  </div>

</div>
  </body>
</html>
